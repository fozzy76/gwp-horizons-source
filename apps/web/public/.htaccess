<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /

	# Google Search Console legacy samples from the previous site.
	RewriteRule ^blog/bighorn-/?$ https://greatwildlifephotos.com/gallery [R=301,L]
	RewriteRule ^about-the-artist/?$ https://greatwildlifephotos.com/about [R=301,L]
	RewriteRule ^warehouse-open-edition-prints/art_print_products/ram-symmetry-lbs-2171/?$ https://greatwildlifephotos.com/gallery [R=301,L]

	# Keep the canonical host and sitemap endpoint unambiguous for crawlers.
	RewriteRule ^sitemap\.xml$ https://api.greatwildlifephotos.com/sitemap.xml [R=301,L]
	RewriteCond %{HTTP_HOST} ^www\.greatwildlifephotos\.com$ [NC]
	RewriteRule ^ https://greatwildlifephotos.com%{REQUEST_URI} [R=301,L]

	RewriteCond %{REQUEST_FILENAME} -f [OR]
	RewriteCond %{REQUEST_FILENAME} -d
	RewriteRule ^ - [L]

	RewriteRule ^(gallery|cart|checkout|order-success|order-receipt|contact|about|faq|privacy|terms|blog)(/.*)?$ /index.html [L]
	RewriteRule ^photo/[^/]+/?$ /index.html [L]
	RewriteRule ^confirmation/[^/]+/?$ /index.html [L]
	RewriteRule ^.+$ / [R=301,L]
</IfModule>

<IfModule mod_headers.c>
	Header set X-Powered-By "Hostinger Horizons"

	# Cache everything on CDN by default
	Header set Cache-Control "public, s-maxage=604800, max-age=0"

	# Cache in browser all assets
	<If "%{REQUEST_URI} =~ m#^/assets/.*$#">
		Header set Cache-Control "public, max-age=604800"
	</If>
</IfModule>
