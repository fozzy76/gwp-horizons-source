<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteBase /
	RewriteCond %{REQUEST_FILENAME} -f [OR]
	RewriteCond %{REQUEST_FILENAME} -d
	RewriteRule ^ - [L]

	RewriteRule ^(gallery|cart|checkout|order-success|order-receipt|contact|about|faq|privacy|terms|blog)(/.*)?$ /index.html [L]
	RewriteRule ^photo/[^/]+/?$ /index.html [L]
	RewriteRule ^confirmation/[^/]+/?$ /index.html [L]
	RewriteRule ^.+$ / [R=301,L]
</IfModule>

<IfModule mod_headers.c>
	Header set X-Powered-By "Hostinger Horizons"

	# Cache everything on CDN by default
	Header set Cache-Control "public, s-maxage=604800, max-age=0"

	# Cache in browser all assets
	<If "%{REQUEST_URI} =~ m#^/assets/.*$#">
		Header set Cache-Control "public, max-age=604800"
	</If>
</IfModule>
